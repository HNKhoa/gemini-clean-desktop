{
  "name": "gemini-clean-desktop",
  "version": "1.0.0",
  "description": "Desktop tool to remove the visible Gemini watermark from local images and videos (Electron + React + MUI + Python).",
  "author": "Gemini Clean",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n vite,api,electron -c green,cyan,magenta \"npm:dev:vite\" \"npm:dev:backend\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:backend": "python backend/server.py",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_DEV=1 electron .",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "package": "vite build && electron-builder --win portable"
  },
  "devDependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.20",
    "@mui/material": "^5.15.20",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.3.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.geminiclean.app",
    "productName": "Gemini Clean",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist",
        "to": "app-dist"
      },
      {
        "from": "backend/pybuild/gcd-backend",
        "to": "gcd-backend"
      },
      {
        "from": "backend/pybuild/ffmpeg",
        "to": "ffmpeg"
      }
    ],
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "GeminiClean-${version}-portable.exe"
    }
  }
}
